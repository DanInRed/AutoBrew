<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:padding="24dp"
    android:gravity="center">

    <!-- Header -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Back"
        android:textColor="#4E342E"
        android:textSize="16sp"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enjoyed your Coffee?"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#4E342E" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Let us know how we did!"
        android:textColor="#757575"
        android:layout_marginTop="8dp" />


    <!-- Review Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_card_bg"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_marginTop="32dp"
        android:elevation="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name of the Worker"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#4E342E" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Rate your experience"
            android:textStyle="bold"
            android:layout_gravity="center" />

        <!-- Rating Stars (Standard Android RatingBar) -->
        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginVertical="16dp"
            android:numStars="5"
            android:stepSize="1"
            android:progressTint="#FFB300" />

        <!-- Comment Box -->
        <EditText
            android:id="@+id/etReviewComment"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/rounded_card_bg"
            android:backgroundTint="#F5F5F5"
            android:gravity="top|start"
            android:hint="Write your feedback here..."
            android:padding="12dp"
            android:textSize="14sp"
            android:inputType="textMultiLine" />

    </LinearLayout>

    <!-- Submit Button -->
    <Button
        android:id="@+id/btnSubmitReview"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:text="SUBMIT REVIEW"
        android:backgroundTint="#4E342E" />

    <TextView
        android:id="@+id/btnSkipReview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Maybe Later"
        android:textColor="#757575"
        android:layout_marginTop="16dp"
        android:padding="8dp"/>

</LinearLayout>